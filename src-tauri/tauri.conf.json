{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AdGuard Manager",
  "version": "0.1.0",
  "identifier": "com.adguard.manager",
  "build": {
    "frontendDist": "../ui"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AdGuard Manager",
        "width": 1100,
        "height": 740,
        "minWidth": 820,
        "minHeight": 520,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
